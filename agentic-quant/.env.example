# =============================================================================
# AGENTIC-QUANT — Environment Variables Template
# Sao chep file nay thanh .env va dien gia tri thuc
# =============================================================================

# --- Anthropic API (Multi-Agent Debate) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Hoac su dung biến môi trường khac neu can thiet

# --- Python ---
PYTHON_EXE=python
# Hoac: python3, py, C:\\Python311\\python.exe

# --- Database ---
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PASSWORD=

# --- Vector DB ---
VECTOR_DB_URL=http://127.0.0.1:6333
# Qdrant collection names
DEBATE_COLLECTION=debate_archive
ZONE_COLLECTION=zone_embeddings

# --- Trading ---
DEFAULT_SYMBOL=XAUUSD
# Hoac EURUSD, GBPUSD, ...

# --- Logging ---
LOG_LEVEL=DEBUG
# DEBUG | INFO | WARNING | ERROR

# --- Backend ---
AGENTIQ_BACKEND=1
